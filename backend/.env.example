# --- Database ---
# connection_limit/pool_timeout are tuned for concurrent booking load — see
# load-test notes in the audit history. Default (no params) is Prisma's
# num_cpus*2+1, which is too small under a burst of simultaneous bookings on
# a 1-2 vCPU host. Keep connection_limit comfortably under the Postgres
# plan's max_connections (leave headroom for admin tools / other clients).
DATABASE_URL="postgresql://ghazal:ghazal_dev_pw@localhost:5432/ghazalkarami?connection_limit=25&pool_timeout=20"

# --- Server ---
PORT=4000
NODE_ENV=development
APP_BASE_URL="http://localhost:4000"
FRONTEND_BASE_URL="http://localhost:4000"

# --- Auth / JWT ---
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"
ADMIN_SEED_PHONE="09120000000"
ADMIN_SEED_PASSWORD="change-me-strong-password"

# --- Kavenegar SMS (placeholder — fill in when available) ---
# these 4 must be created as approved Lookup/Verify patterns in the Kavenegar
# panel first (plain free-text SMS is not allowed for transactional messages):
#   KAVENEGAR_TEMPLATE_OTP            — %token% = 6-digit code
#   KAVENEGAR_TEMPLATE_BOOKING_CONFIRM — %token%=service name, %token2%=date, %token3%=time
#   KAVENEGAR_TEMPLATE_REMINDER        — %token%=service name, %token2%=date, %token3%=time
#   KAVENEGAR_TEMPLATE_THANKYOU_REVIEW — %token%=service name, %token2%=review page link
#   KAVENEGAR_TEMPLATE_REFUND          — %token%=service name, %token2%=refunded amount (toman)
KAVENEGAR_API_KEY=""
KAVENEGAR_TEMPLATE_OTP=""
KAVENEGAR_TEMPLATE_BOOKING_CONFIRM=""
KAVENEGAR_TEMPLATE_REMINDER=""
KAVENEGAR_TEMPLATE_THANKYOU_REVIEW=""
KAVENEGAR_TEMPLATE_REFUND=""

# --- ZarinPal payment (placeholder — fill in when available) ---
ZARINPAL_MERCHANT_ID=""
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL="http://localhost:4000/api/payments/zarinpal/callback"

# --- ZarinPal Refund API (SEPARATE from the Merchant ID above — see
# services/zarinpalRefund.ts) ---
# The refund API (https://www.zarinpal.com/docs/apiDocs/query/refund) runs on
# ZarinPal's OAuth2 platform, not the classic Merchant ID gateway. As of this
# writing we do NOT have these credentials — client_id/client_secret must be
# requested from ZarinPal support directly (not available self-service from
# the merchant panel). Until these are set, automatic refunds always resolve
# to "needs manual follow-up" and Ghazal must issue them by hand.
# Fee: 1500 Toman base + 250 Toman per extra 1,000,000 Toman refunded,
# deducted from the salon's ZarinPal balance.
ZARINPAL_REFUND_CLIENT_ID=""
ZARINPAL_REFUND_CLIENT_SECRET=""
ZARINPAL_REFUND_USERNAME=""
ZARINPAL_REFUND_PASSWORD=""

# --- Object storage for uploaded images (gallery, logo, profile photos) ---
# REQUIRED in production — without these, uploads fall back to local disk,
# which a PaaS app container does not guarantee to keep across a plan resize
# or redeploy. Any S3-compatible provider works (Liara Object Storage, Arvan,
# MinIO, AWS S3, ...) — point OBJECT_STORAGE_ENDPOINT at that provider's
# S3-compatible endpoint and create a bucket with public-read access for
# served assets.
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_REGION="us-east-1"
OBJECT_STORAGE_ACCESS_KEY=""
OBJECT_STORAGE_SECRET_KEY=""
OBJECT_STORAGE_BUCKET=""
# leave empty to default to "<endpoint>/<bucket>" (path-style); set this only
# if serving uploads through a CDN or custom domain in front of the bucket
OBJECT_STORAGE_PUBLIC_URL=""
